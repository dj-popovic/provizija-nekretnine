# Runtime
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# XML feed (required)
XML_FEED_URL=https://your-relper-feed-url-here

# XML refresh interval in milliseconds (default: 3600000 = 1 hour)
XML_REFRESH_INTERVAL_MS=3600000

# CORS — comma-separated origins or * for all
CORS_ORIGIN=http://localhost:5173

# Rate limiting
# RATE_LIMIT_MAX=100
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_FORMS_MAX=5
# RATE_LIMIT_FORMS_WINDOW_MS=60000

# Email (Resend)
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=noreply@yourdomain.com
AGENCY_EMAIL=pro.vizijanekretnine@gmail.com

# Development only — enable manual sync trigger endpoint
MANUAL_REFRESH_ENABLED=false
