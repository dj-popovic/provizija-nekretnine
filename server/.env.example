# Runtime
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# XML feed (required)
XML_FEED_URL=https://your-relper-feed-url-here

# XML refresh interval in milliseconds (default: 3600000 = 1 hour)
XML_REFRESH_INTERVAL_MS=3600000

# CORS — comma-separated origins or * for all (Phase 12)
CORS_ORIGIN=http://localhost:5173

# Email — SMTP config (Phase 11)
EMAIL_FROM=noreply@yourdomain.com
EMAIL_SMTP_HOST=smtp.yourprovider.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your_smtp_user
EMAIL_SMTP_PASS=your_smtp_password

# Development only — enable manual sync trigger endpoint
MANUAL_REFRESH_ENABLED=false
